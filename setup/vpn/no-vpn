#!/bin/bash

if [ $# -eq 0 ]; then
    echo "Использование: no-vpn <команда> [аргументы...]" >&2
    echo "Пример: MY_VAR=123 no-vpn bash" >&2
    exit 1
fi

# Получаем имя пользователя
if [ -n "$SUDO_USER" ] && [ "$SUDO_USER" != "root" ]; then
    USER_TO_RUN="$SUDO_USER"
else
    USER_TO_RUN="$USER"
fi

# Захватываем окружение
SAVED_ENV=$(export -p | grep -vE ' (UID|EUID|PPID|SUDO_.*|BASH_.*)=')

# -m -n: возвращаемся и в mount-ns, и в net-ns хоста (PID 1). Без -m остаётся
# mount-ns вызывающего: например, под 'vpn2' там натянут overlay
# /etc/resolv.conf -> 127.0.0.1 (DNS внутри socks-ns), и резолвинг на хосте ломается.
sudo nsenter -t 1 -m -n sudo -u "$USER_TO_RUN" bash -c '
    eval "$1"
    cd "$2"
    shift 2
    "$@"
' -- "$SAVED_ENV" "$PWD" "$@"
