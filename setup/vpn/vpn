#!/bin/bash

NS_NAME="vpn"

if ! ip netns list | grep -q "$NS_NAME"; then
    echo "Ошибка: Неймспейс '$NS_NAME' не существует" >&2
    echo "Запустите сначала: sudo systemctl start setup-vpn-ns.service" >&2
    exit 1
fi

if [ $# -eq 0 ]; then
    echo "Использование: vpn2 <команда> [аргументы...]" >&2
    echo "Пример: MY_VAR=123 vpn2 bash" >&2
    exit 1
fi

# Получаем имя пользователя
if [ -n "$SUDO_USER" ] && [ "$SUDO_USER" != "root" ]; then
    USER_TO_RUN="$SUDO_USER"
else
    USER_TO_RUN="$USER"
fi

# Захватываем окружение (исключаем системные переменные, которые нельзя переопределять)
SAVED_ENV=$(export -p | grep -vE ' (UID|EUID|PPID|SUDO_.*|BASH_.*)=')

# Убран флаг -i у внутреннего sudo, так как мы полностью восстанавливаем окружение руками
sudo ip netns exec "$NS_NAME" sudo -u "$USER_TO_RUN" bash -c '
    eval "$1"
    cd "$2"
    shift 2
    "$@"
' -- "$SAVED_ENV" "$PWD" "$@"
